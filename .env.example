# 환경변수 설정 파일
# 이 파일을 복사해서 .env 파일을 만들고 실제 값으로 채워주세요.
# cp .env.example .env

# 어드민 로그인 자격증명
ADMIN_ID=admin
ADMIN_PW=your_secure_password_here

# 세션 암호화 키 (긴 랜덤 문자열로 교체하세요)
SESSION_SECRET=change_this_to_a_long_random_secret_string

# Neon Postgres 연결 문자열
# Neon 콘솔(https://console.neon.tech)에서 프로젝트 생성 후 복사하세요
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
